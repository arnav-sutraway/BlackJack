# Copy this file to .env and fill in your own values.
# .env is gitignored so each teammate sets their own.

# Path to your trained YOLO model weights
# Example (Mac): MODEL_PATH=/Users/yourname/Downloads/detect/train4/weights/best.pt
# Example (relative, if you copy best.pt next to camera.py): MODEL_PATH=best.pt
MODEL_PATH=best.pt

# IP Webcam stream URL from your phone (shown on the app screen)
# iPhone/Android: install "IP Webcam" or "DroidCam", check the URL it shows
CAMERA_URL=http://192.168.1.100:8080/video

# Gemini API key (used by advisorbot.py)
GEMINI_API_KEY=your_gemini_api_key_here
